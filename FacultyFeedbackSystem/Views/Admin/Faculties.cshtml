@model IEnumerable<FacultyFeedbackSystem.Models.Faculty>
@{
    ViewData["Title"] = "Manage Faculties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Faculties</h2>
    <a asp-action="CreateFaculty" class="btn btn-primary">Add New Faculty</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Department</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Join Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var faculty in Model)
        {
            <tr>
                <td>@faculty.Name</td>
                <td>@faculty.Department</td>
                <td>@faculty.Email</td>
                <td>@faculty.Phone</td>
                <td>@faculty.JoinDate.ToString("dd/MM/yyyy")</td>
                <td>
                    <a href="#" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a href="#" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
