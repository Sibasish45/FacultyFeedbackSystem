@model FacultyFeedbackSystem.Models.Subject

@{
    ViewData["Title"] = "Add Subject";
}

<h2 class="mb-4">➕ Add New Subject</h2>

@* Show validation summary if model state is invalid *@
@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<form asp-action="CreateSubject" method="post">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="SName" class="form-label">Subject Name</label>
            <input asp-for="SName" class="form-control" />
            <span asp-validation-for="SName" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Code" class="form-label">Subject Code</label>
            <input asp-for="Code" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="FacultyID" class="form-label">Faculty</label>
            <select asp-for="FacultyID" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Faculties, "FacultyID", "Name"))">
                <option value="">Select Faculty</option>
            </select>
            <option value="">-- Select Faculty --</option>
            </select>
            <span asp-validation-for="FacultyID" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Semester" class="form-label">Semester</label>
            <input asp-for="Semester" class="form-control" />
            <span asp-validation-for="Semester" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Credits" class="form-label">Credits</label>
            <input asp-for="Credits" class="form-control" type="number" />
            <span asp-validation-for="Credits" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary"> Add Subject</button>
        <a asp-action="Subjects" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}