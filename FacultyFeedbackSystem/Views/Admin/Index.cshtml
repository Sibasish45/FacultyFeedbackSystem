@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row">
    <div class="col-md-12">
        <h2>Admin Dashboard</h2>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h4>@Model.TotalFaculties</h4>
                <p>Total Faculties</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h4>@Model.TotalSubjects</h4>
                <p>Total Subjects</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h4>@Model.TotalStudents</h4>
                <p>Total Students</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <h4>@Model.TotalFeedbacks</h4>
                <p>Total Feedbacks</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <a asp-action="Faculties" class="btn btn-primary btn-lg btn-block">Manage Faculties</a>
    </div>
    <div class="col-md-4">
        <a asp-action="Subjects" class="btn btn-success btn-lg btn-block">Manage Subjects</a>
    </div>
    <div class="col-md-4">
        <a asp-action="Reports" class="btn btn-info btn-lg btn-block">View Reports</a>
    </div>
</div>

