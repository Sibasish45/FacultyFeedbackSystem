@model FacultyFeedbackSystem.ViewModels.FeedbackViewModel

@{
    ViewData["Title"] = "Submit Feedback";
}

<h2>Submit Feedback</h2>
<div class="card">
    <div class="card-header">
        <h4>@Model.SubjectName - @Model.FacultyName</h4>
    </div>
    <div class="card-body">
        <form asp-action="SubmitFeedback" method="post">
            <input asp-for="SubjectID" type="hidden" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Discipline" class="form-label">Discipline (1-5)</label>
                        <select asp-for="Discipline" class="form-control">
                            <option value="">Select Rating</option>
                            <option value="1">1 - Poor</option>
                            <option value="2">2 - Fair</option>
                            <option value="3">3 - Good</option>
                            <option value="4">4 - Very Good</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                        <span asp-validation-for="Discipline" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Clarity" class="form-label">Clarity (1-5)</label>
                        <select asp-for="Clarity" class="form-control">
                            <option value="">Select Rating</option>
                            <option value="1">1 - Poor</option>
                            <option value="2">2 - Fair</option>
                            <option value="3">3 - Good</option>
                            <option value="4">4 - Very Good</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                        <span asp-validation-for="Clarity" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Teaching" class="form-label">Teaching Method (1-5)</label>
                        <select asp-for="Teaching" class="form-control">
                            <option value="">Select Rating</option>
                            <option value="1">1 - Poor</option>
                            <option value="2">2 - Fair</option>
                            <option value="3">3 - Good</option>
                            <option value="4">4 - Very Good</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                        <span asp-validation-for="Teaching" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Knowledge" class="form-label">Subject Knowledge (1-5)</label>
                        <select asp-for="Knowledge" class="form-control">
                            <option value="">Select Rating</option>
                            <option value="1">1 - Poor</option>
                            <option value="2">2 - Fair</option>
                            <option value="3">3 - Good</option>
                            <option value="4">4 - Very Good</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                        <span asp-validation-for="Knowledge" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Punctuality" class="form-label">Punctuality (1-5)</label>
                        <select asp-for="Punctuality" class="form-control">
                            <option value="">Select Rating</option>
                            <option value="1">1 - Poor</option>
                            <option value="2">2 - Fair</option>
                            <option value="3">3 - Good</option>
                            <option value="4">4 - Very Good</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                        <span asp-validation-for="Punctuality" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Comments" class="form-label">Additional Comments</label>
                <textarea asp-for="Comments" class="form-control" rows="4" placeholder="Please provide any additional comments or suggestions..."></textarea>
                <span asp-validation-for="Comments" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Submit Feedback</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
